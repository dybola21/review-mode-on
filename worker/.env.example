# ---- Server ----
PORT=3000
LOG_LEVEL=info

# ---- Auth (required, min 32 chars) ----
# Shared bearer used by the Lovable app when calling POST /jobs.
WORKER_API_KEY=

# Public URL of THIS worker (used only for logs / self-reference).
WORKER_PUBLIC_URL=

# ---- Callback to Lovable app ----
# Full URL of the Lovable webhook endpoint.
APP_WEBHOOK_URL=
# Same value stored in Lovable as VIDEO_WORKER_WEBHOOK_SECRET (min 32 chars).
APP_WEBHOOK_SECRET=

# ---- Storage / disk ----
DATA_DIR=/data
TEMP_DIR=/tmp/editor-worker

# ---- Concurrency / limits ----
MAX_CONCURRENCY=1
MAX_INPUT_BYTES=524288000          # 500 MiB per download
MAX_OUTPUT_BYTES=524288000         # 500 MiB per rendered output
MAX_JOB_DURATION_SECONDS=1800      # whole-job wall clock cap
FFMPEG_TIMEOUT_SECONDS=900         # per ffmpeg invocation

# ---- Host allowlists (comma-separated hostnames) ----
# Signed URLs for input downloads and output uploads must match one of these.
# Example: xxxx.supabase.co
ALLOWED_DOWNLOAD_HOSTS=
ALLOWED_UPLOAD_HOSTS=
